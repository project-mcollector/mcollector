{
  "name": "@mcollector/sdk",
  "version": "1.0.0",
  "description": "mcollector JavaScript SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "analytics"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "jsdom": "^29.0.2",
    "tsup": "^8.0.2",
    "typescript": "^5.4.2",
    "vitest": "^4.1.4"
  }
}
