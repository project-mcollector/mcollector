{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "dev": {
            "cache": false
        },
        "build": {
            "dependsOn": ["^build"],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "bin/**",
                "apps/api/**/bin/**",
                "apps/api/**/obj/**"
            ]
        }
    }
}
